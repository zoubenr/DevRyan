{
  "name": "@openchamber/electron",
  "version": "1.0.11",
  "private": true,
  "description": "Electron desktop runtime for DevRyan",
  "author": "DevRyan",
  "type": "module",
  "main": "./dist-bundle/main.mjs",
  "dependencies": {
    "@openchamber/web": "workspace:*",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.0.0"
  },
  "desktopPrerequisites": [
    "Electron runtime dependencies installed via bun install",
    "Bun available for sidecar compilation",
    "macOS build tools installed for notarized packaging"
  ],
  "scripts": {
    "postinstall": "node ./scripts/sign-dev-electron.mjs",
    "dev": "node ./scripts/electron-dev.mjs",
    "build:web-assets": "node ./scripts/build-web-assets.mjs",
    "build": "bun -e \"process.exit(0)\"",
    "bundle:main": "bun ./scripts/bundle-main.mjs",
    "rebuild:native": "node ./scripts/rebuild-native.mjs",
    "build:speech-helper": "node ./scripts/build-speech-helper.mjs",
    "package": "bun run build:web-assets && bun run build:speech-helper && bun run bundle:main && bun run rebuild:native && electron-builder",
    "finalize:latest-yml": "node ./scripts/finalize-latest-yml.mjs",
    "type-check": "node --check ./origin-policy.mjs && node --check ./main.mjs && node --check ./preload.mjs",
    "lint": "node -e \"process.exit(0)\""
  },
  "build": {
    "appId": "dev.openchamber.desktop",
    "productName": "DevRyan",
    "files": [
      "dist-bundle/main.mjs",
      "preload.mjs",
      "origin-policy.mjs"
    ],
    "extraResources": [
      {
        "from": "resources/web-dist",
        "to": "web-dist"
      },
      {
        "from": "resources/native",
        "to": "native"
      }
    ],
    "directories": {
      "buildResources": "resources/icons",
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "afterPack": "./scripts/adhoc-sign-macos-app.mjs",
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icons/icon.icns",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "DevRyan needs to run the OpenCode CLI to provide AI coding assistance.",
        "NSDesktopFolderUsageDescription": "DevRyan needs access to work with your projects.",
        "NSDocumentsFolderUsageDescription": "DevRyan needs access to work with your projects.",
        "NSDownloadsFolderUsageDescription": "DevRyan needs access to work with your projects.",
        "NSMicrophoneUsageDescription": "DevRyan uses your microphone to transcribe voice input.",
        "NSSpeechRecognitionUsageDescription": "DevRyan uses Apple Speech Recognition to turn your spoken prompts into text."
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "sign": true,
      "title": "${productName} ${version}",
      "backgroundColor": "#FFFCF0",
      "iconSize": 100,
      "iconTextSize": 13,
      "window": {
        "width": 540,
        "height": 340
      },
      "contents": [
        {
          "x": 180,
          "y": 140,
          "type": "file"
        },
        {
          "x": 360,
          "y": 140,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "btriapitsyn",
      "repo": "openchamber"
    }
  }
}
