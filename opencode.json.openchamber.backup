{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mobbin": {
      "command": [
        "/opt/homebrew/bin/npx",
        "-y",
        "mobbin-mcp@latest"
      ],
      "enabled": true,
      "environment": {
        "HOME": "/Users/zoubair"
      },
      "type": "local"
    },
    "railway": {
      "command": [
        "railway",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}