{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true,
  "mcp": {
    "mobbin": {
      "command": [
        "/opt/homebrew/bin/npx",
        "-y",
        "mobbin-mcp@latest"
      ],
      "enabled": true,
      "environment": {
        "HOME": "/Users/zoubair"
      },
      "type": "local"
    },
    "railway": {
      "command": [
        "railway",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "./plugins/orchestrator-autoresume.mjs",
    "opencode-with-claude",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy"
      }
    }
  }
}
